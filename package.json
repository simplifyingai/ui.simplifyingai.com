{
  "name": "simplify-charts",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "800+ beautiful chart components for React. Copy. Paste. Ship.",
  "author": {
    "name": "Simplifying AI",
    "url": "https://simplifyingai.com"
  },
  "homepage": "https://ui.simplifyingai.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simplifying-ai/charts.git"
  },
  "bugs": {
    "url": "https://github.com/simplifying-ai/charts/issues"
  },
  "keywords": [
    "react",
    "charts",
    "data-visualization",
    "tailwindcss",
    "shadcn",
    "recharts",
    "d3",
    "simplify-charts",
    "bar-chart",
    "line-chart",
    "pie-chart",
    "candlestick",
    "choropleth",
    "heatmap",
    "sankey",
    "treemap",
    "box-plot",
    "violin-chart"
  ],
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:registry": "pnpm --filter=www build:registry && pnpm lint:fix && pnpm format:write -- --loglevel silent",
    "registry:build": "pnpm --filter=www registry:build && pnpm lint:fix && pnpm format:write -- --loglevel silent",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "format:write": "turbo run format:write",
    "format:check": "turbo run format:check",
    "check": "turbo lint typecheck format:check",
    "release": "changeset version",
    "validate:registries": "pnpm validate:registries"
  },
  "packageManager": "pnpm@9.0.6",
  "dependencies": {
    "@babel/core": "^7.22.1",
    "@changesets/changelog-github": "^0.4.8",
    "@changesets/cli": "^2.26.1",
    "@commitlint/cli": "^17.6.3",
    "@commitlint/config-conventional": "^17.6.3",
    "@ianvs/prettier-plugin-sort-imports": "^3.7.2",
    "@manypkg/cli": "^0.20.0",
    "@typescript-eslint/parser": "^5.59.7",
    "autoprefixer": "^10.4.14",
    "concurrently": "^8.0.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.41.0",
    "eslint-config-next": "13.3.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-config-turbo": "^1.9.9",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-tailwindcss": "3.13.1",
    "motion": "^12.12.1",
    "postcss": "^8.4.24",
    "prettier": "^2.8.8",
    "pretty-quick": "^3.1.3",
    "puppeteer": "^23.6.0",
    "tailwindcss": "3.4.6",
    "tailwindcss-animate": "^1.0.5",
    "tsx": "^4.1.4",
    "turbo": "^2.6.0"
  },
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "@types/node": "^20.11.27",
    "@types/react": "^18.2.65",
    "@types/react-dom": "^18.2.22",
    "typescript": "^5.5.3"
  }
}
